        "templates": [
            {
                "id": "T001",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE})-[:$REL_TYPE]-()-[:$REL_TYPE]-(b:$LABEL2) WHERE NOT (a)-[:$REL_TYPE]-(b) RETURN b.$RETURN_PROP",
                "parameters": {
                    "LABEL1": "string",
                    "LABEL2": "string",
                    "PROP1": "string",
                    "VALUE": "string",
                    "REL_TYPE": "string",
                    "RETURN_PROP": "string"
                }
            },
            {
                "id": "T002",
                "template": "MATCH (a:$LABEL)-[:$REL2]->(:$LABEL3) WHERE NOT (a)-[:$REL1]->(:$LABEL2) RETURN a.$RET_PROP",
                "parameters": {
                    "LABEL": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "REL1": "string",
                    "REL2": "string",
                    "RET_PROP": "string"
                }
            }
        ]
    },
    {
        "type": "union",
        "templates": [
            {
                "id": "T001",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE}) RETURN a.$PROP1 UNION MATCH (b:$LABEL2 {$PROP2: $VALUE2}) RETURN b.$PROP2",
                "parameters": {
