[
    {
        "type": "chain",
        "templates": [
            {
                "id": "T001",
                "template": "MATCH (a:$LABEL1 {$PROP_ID: $VALUE})-[:$REL1]->(b:$LABEL2)-[:$REL2]->(c:$LABEL3)-[:$REL3]->(d:$LABEL4) RETURN a, b, d",
                "parameters": {
                    "LABEL1": "string",
                    "PROP_ID": "string",
                    "VALUE": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "LABEL4": "string",
                    "REL1": "string",
                    "REL2": "string",
                    "REL3": "string"
                }
            },
            {
                "id": "T002",
                "template": "MATCH (a:$LABEL1 {$PROP_ID: $VALUE})-[:$REL_TYPE *$MIN_HOPS..$MAX_HOPS]-(b:$LABEL2) RETURN a, b",
                "parameters": {
                    "LABEL1": "string",
                    "PROP_ID": "string",
                    "VALUE": "string",
                    "LABEL2": "string",
                    "REL_TYPE": "string",
                    "MIN_HOPS": "integer",
                    "MAX_HOPS": "integer"
                }
            },
            {
                "id": "T003",
                "template": "MATCH (start:$START_LABEL {$START_PROP: $START_VALUE}) MATCH p = (start) ((n1:$LABEL2)<-$D1[:$R1]-$D2(r:$REL_NODE_LABEL)-$D3[:$R2]->(n2:$LABEL3) WHERE r.$NODE_PROP = $NODE_VALUE){$MIN_HOPS..$MAX_HOPS} (end:$END_LABEL) RETURN p",
                "parameters": {
                    "START_LABEL": "string",
                    "START_PROP": "string",
                    "START_VALUE": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "D1": "string",
                    "D2": "string",
                    "D3": "string",
                    "R1": "string",
                    "R2": "string",
                    "REL_NODE_LABEL": "string",
                    "NODE_PROP": "string",
                    "NODE_VALUE": "string",
                    "MIN_HOPS": "integer",
                    "MAX_HOPS": "integer",
                    "END_LABEL": "string"
                }
            }
        ]
    },
    {
        "type": "pipelined",
        "templates": [
            {
                "id": "T001",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE})-[:$REL1]->(b:$LABEL2) WITH b MATCH (b)-[:$REL2]->(c:$LABEL3) RETURN b.$RET_PROP1, c.$RET_PROP2",
                "parameters": {
                    "LABEL1": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "PROP1": "string",
                    "VALUE": "string",
                    "REL1": "string",
                    "REL2": "string",
                    "RET_PROP1": "string",
                    "RET_PROP2": "string"
                }
            },
            {
                "id": "T002",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE})-[:$REL1]->(b:$LABEL2) WITH b MATCH (b)-[:$REL2]->(c:$LABEL3) WITH b, c MATCH (c)-[:$REL3]->(d:$LABEL4) RETURN b.$RET_PROP1, c.$RET_PROP2, d.$RET_PROP3",
                "parameters": {
                    "LABEL1": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "LABEL4": "string",
                    "PROP1": "string",
                    "VALUE": "string",
                    "REL1": "string",
                    "REL2": "string",
                    "REL3": "string",
                    "RET_PROP1": "string",
                    "RET_PROP2": "string",
                    "RET_PROP3": "string"
                }
            },
            {
                "id": "T003",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE})-[:$REL1]->(b:$LABEL2) WITH b MATCH (b)-[:$REL2]->(c:$LABEL3) WHERE c.$FILTER_PROP = $FILTER_VAL WITH b, c MATCH (c)-[:$REL3]->(d:$LABEL4) RETURN b.$RET_PROP1, c.$RET_PROP2, d.$RET_PROP3",
                "parameters": {
                    "LABEL1": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "LABEL4": "string",
                    "PROP1": "string",
                    "VALUE": "string",
                    "REL1": "string",
                    "REL2": "string",
                    "REL3": "string",
                    "FILTER_PROP": "string",
                    "FILTER_VAL": "string",
                    "RET_PROP1": "string",
                    "RET_PROP2": "string",
                    "RET_PROP3": "string"
                }
            }
        ]
    },
    {
        "type": "basic",
        "templates": [
            {
                "id": "T002",
                "template": "MATCH (n:$LABEL {$PROP: $VALUE})-[:$REL_TYPE]->(m) RETURN m",
                "parameters": {
                    "LABEL": "string",
                    "PROP": "string",
                    "VALUE": "string",
                    "REL_TYPE": "string"
                }
            },
            {
                "id": "T003",
                "template": "MATCH (a:$LABEL1 {$PROP_ID: $VALUE})-[:$REL1]->(b:$LABEL2) MATCH (a)-[:$REL2]->(b) RETURN a, b",
                "parameters": {
                    "LABEL1": "string",
                    "PROP_ID": "string",
                    "VALUE": "string",
                    "LABEL2": "string",
                    "REL1": "string",
                    "REL2": "string"
                }
            },
            {
                "id": "T004",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE1})-[:$REL]-(b:$LABEL2) WHERE b.$PROP $OP $VALUE RETURN a",
                "parameters": {
                    "LABEL1": "string",
                    "PROP1": "string",
                    "VALUE1": "string",
                    "REL": "string",
                    "LABEL2": "string",
                    "PROP": "string",
                    "OP": "string",
                    "VALUE2": "string"
                }
            }
        ]
    },
    {
        "type": "nested_loop",
        "templates": [
            {
                "id": "T001",
                "template": "MATCH (a:$LABEL1 {$PROP1: $VALUE}) MATCH (b:$LABEL2 {$PROP2: a.$REF_PROP}) WHERE a <> b RETURN a, b",
                "parameters": {
                    "LABEL1": "string",
                    "LABEL2": "string",
                    "PROP1": "string",
                    "PROP2": "string",
                    "VALUE": "string",
                    "REF_PROP": "string"
                }
            },
            {
                "id": "T002",
                "template": "MATCH (a:$LABEL1) WHERE (a)-[:$REL_TYPE]->(:$LABEL2 {$PROP_ID: $VALUE}) RETURN a.$RETURN_PROP",
                "parameters": {
                    "LABEL1": "string",
                    "LABEL2": "string",
                    "PROP_ID": "string",
                    "VALUE": "string",
                    "REL_TYPE": "string",
                    "RETURN_PROP": "string"
                }
            },
            {
                "id": "T004",
                "template": "MATCH (n:$LABEL) WHERE (n)-[:$REL1]->(:$LABEL2 {$PROP_I1: $VALUE1}) OR (n)-[:$REL2]->(:$LABEL3 {$PROP_ID2: $VALUE2}) RETURN n.$PROP",
                "parameters": {
                    "LABEL": "string",
                    "REL1": "string",
                    "LABEL2": "string",
                    "PROP_ID1": "string",
                    "VALUE1": "string",
                    "REL2": "string",
                    "LABEL3": "string",
                    "PROP_ID2": "string",
                    "VALUE2": "string",
                    "PROP": "string"
                }
            },
            {
                "id": "T005",
                "template": "MATCH (n:$LABEL) WHERE NOT (n)-[:$REL1]->(:$LABEL2) OR (n)-[:$REL2]->(:$LABEL3) RETURN n.$PROP",
                "parameters": {
                    "LABEL": "string",
                    "REL1": "string",
                    "REL2": "string",
                    "LABEL2": "string",
                    "LABEL3": "string",
                    "PROP": "string"
                }
            },
            {
                "id": "T006",
                "template": "MATCH (n:$LABEL) WHERE n.$PROP $OP $VAL OR (n)-[:$REL]->(:$LABEL2) RETURN n.$RET",
                "parameters": {
                    "LABEL": "string",
                    "PROP": "string",
                    "OP": "string",
                    "VAL": "string",
                    "REL": "string",
                    "LABEL2": "string",
                    "RET": "string"
                }
            }
        ]
    },
    {
